{
  "title": "SIEM Platform Health",
  "uid": "siem-platform-health",
  "tags": ["siem", "infraestructura"],
  "timezone": "browser",
  "refresh": "30s",
  "schemaVersion": 38,
  "panels": [

    {
      "id": 1, "type": "stat", "title": "Conexiones activas a DB",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "postgres", "uid": "siem-postgres" },
      "options": { "colorMode": "background", "graphMode": "none", "textMode": "auto" },
      "fieldConfig": { "defaults": {
        "thresholds": { "mode": "absolute", "steps": [
          { "color": "green", "value": null },
          { "color": "yellow", "value": 10 },
          { "color": "red", "value": 25 }
        ]},
        "mappings": []
      }, "overrides": [] },
      "targets": [{ "datasource": { "uid": "siem-postgres" }, "rawSql": "SELECT count(*) AS value FROM pg_stat_activity WHERE datname = 'siem'", "format": "table", "rawQuery": true, "refId": "A" }]
    },

    {
      "id": 2, "type": "stat", "title": "Tamaño de la base de datos",
      "gridPos": { "x": 4, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "postgres", "uid": "siem-postgres" },
      "options": { "colorMode": "value", "graphMode": "none", "textMode": "auto" },
      "fieldConfig": { "defaults": { "unit": "decbytes", "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] }, "mappings": [] }, "overrides": [] },
      "targets": [{ "datasource": { "uid": "siem-postgres" }, "rawSql": "SELECT pg_database_size('siem') AS value", "format": "table", "rawQuery": true, "refId": "A" }]
    },

    {
      "id": 3, "type": "gauge", "title": "Cache Hit Ratio DB (%)",
      "gridPos": { "x": 8, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "postgres", "uid": "siem-postgres" },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "minVizWidth": 75 },
      "fieldConfig": { "defaults": {
        "min": 0, "max": 100, "unit": "percent",
        "thresholds": { "mode": "absolute", "steps": [
          { "color": "red", "value": null },
          { "color": "yellow", "value": 80 },
          { "color": "green", "value": 95 }
        ]},
        "mappings": []
      }, "overrides": [] },
      "targets": [{ "datasource": { "uid": "siem-postgres" }, "rawSql": "SELECT ROUND(blks_hit::numeric / NULLIF(blks_hit + blks_read, 0) * 100, 1) AS value FROM pg_stat_database WHERE datname = 'siem'", "format": "table", "rawQuery": true, "refId": "A" }]
    },

    {
      "id": 4, "type": "stat", "title": "Transacciones comprometidas",
      "gridPos": { "x": 12, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "postgres", "uid": "siem-postgres" },
      "options": { "colorMode": "value", "graphMode": "area", "textMode": "auto" },
      "fieldConfig": { "defaults": { "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] }, "mappings": [] }, "overrides": [] },
      "targets": [{ "datasource": { "uid": "siem-postgres" }, "rawSql": "SELECT xact_commit AS value FROM pg_stat_database WHERE datname = 'siem'", "format": "table", "rawQuery": true, "refId": "A" }]
    },

    {
      "id": 5, "type": "stat", "title": "Deadlocks detectados",
      "gridPos": { "x": 16, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "postgres", "uid": "siem-postgres" },
      "options": { "colorMode": "background", "graphMode": "none", "textMode": "auto" },
      "fieldConfig": { "defaults": {
        "thresholds": { "mode": "absolute", "steps": [
          { "color": "green", "value": null },
          { "color": "red", "value": 1 }
        ]},
        "mappings": []
      }, "overrides": [] },
      "targets": [{ "datasource": { "uid": "siem-postgres" }, "rawSql": "SELECT deadlocks AS value FROM pg_stat_database WHERE datname = 'siem'", "format": "table", "rawQuery": true, "refId": "A" }]
    },

    {
      "id": 6, "type": "stat", "title": "Queries activas ahora",
      "gridPos": { "x": 20, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "postgres", "uid": "siem-postgres" },
      "options": { "colorMode": "background", "graphMode": "none", "textMode": "auto" },
      "fieldConfig": { "defaults": {
        "thresholds": { "mode": "absolute", "steps": [
          { "color": "green", "value": null },
          { "color": "yellow", "value": 5 },
          { "color": "red", "value": 15 }
        ]},
        "mappings": []
      }, "overrides": [] },
      "targets": [{ "datasource": { "uid": "siem-postgres" }, "rawSql": "SELECT count(*) AS value FROM pg_stat_activity WHERE datname = 'siem' AND state = 'active'", "format": "table", "rawQuery": true, "refId": "A" }]
    },

    {
      "id": 7, "type": "table", "title": "Tamaño de tablas principales",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "datasource": { "type": "postgres", "uid": "siem-postgres" },
      "options": { "showHeader": true, "cellHeight": "sm", "footer": { "show": false } },
      "fieldConfig": { "defaults": { "custom": { "align": "left" } }, "overrides": [] },
      "targets": [{ "datasource": { "uid": "siem-postgres" }, "rawSql": "SELECT relname AS tabla, pg_size_pretty(pg_total_relation_size(relid)) AS tamaño_total, pg_size_pretty(pg_relation_size(relid)) AS tamaño_datos, n_live_tup AS filas_vivas, n_dead_tup AS filas_muertas FROM pg_stat_user_tables WHERE schemaname = 'public' ORDER BY pg_total_relation_size(relid) DESC", "format": "table", "rawQuery": true, "refId": "A" }]
    },

    {
      "id": 8, "type": "table", "title": "Conexiones activas por estado",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "datasource": { "type": "postgres", "uid": "siem-postgres" },
      "options": { "showHeader": true, "cellHeight": "sm", "footer": { "show": false } },
      "fieldConfig": { "defaults": { "custom": { "align": "left" } }, "overrides": [] },
      "targets": [{ "datasource": { "uid": "siem-postgres" }, "rawSql": "SELECT state AS estado, usename AS usuario, application_name AS aplicacion, count(*) AS conexiones FROM pg_stat_activity WHERE datname = 'siem' GROUP BY state, usename, application_name ORDER BY conexiones DESC", "format": "table", "rawQuery": true, "refId": "A" }]
    },

    {
      "id": 9, "type": "stat", "title": "Detector — minutos desde última alerta",
      "description": "Proxy de salud del detector. Si supera 10 min puede indicar que el detector está caído.",
      "gridPos": { "x": 0, "y": 12, "w": 6, "h": 4 },
      "datasource": { "type": "postgres", "uid": "siem-postgres" },
      "options": { "colorMode": "background", "graphMode": "none", "textMode": "auto" },
      "fieldConfig": { "defaults": {
        "unit": "m",
        "thresholds": { "mode": "absolute", "steps": [
          { "color": "green", "value": null },
          { "color": "yellow", "value": 5 },
          { "color": "red", "value": 10 }
        ]},
        "mappings": []
      }, "overrides": [] },
      "targets": [{ "datasource": { "uid": "siem-postgres" }, "rawSql": "SELECT ROUND(EXTRACT(EPOCH FROM (NOW() - MAX(ts)))/60, 1) AS value FROM alerts", "format": "table", "rawQuery": true, "refId": "A" }]
    },

    {
      "id": 10, "type": "stat", "title": "n8n — minutos desde último playbook",
      "description": "Proxy de salud de n8n. Si supera 15 min con alertas activas puede indicar que n8n está caído.",
      "gridPos": { "x": 6, "y": 12, "w": 6, "h": 4 },
      "datasource": { "type": "postgres", "uid": "siem-postgres" },
      "options": { "colorMode": "background", "graphMode": "none", "textMode": "auto" },
      "fieldConfig": { "defaults": {
        "unit": "m",
        "thresholds": { "mode": "absolute", "steps": [
          { "color": "green", "value": null },
          { "color": "yellow", "value": 10 },
          { "color": "red", "value": 15 }
        ]},
        "mappings": []
      }, "overrides": [] },
      "targets": [{ "datasource": { "uid": "siem-postgres" }, "rawSql": "SELECT ROUND(EXTRACT(EPOCH FROM (NOW() - MAX(executed_at)))/60, 1) AS value FROM playbook_runs", "format": "table", "rawQuery": true, "refId": "A" }]
    },

    {
      "id": 11, "type": "stat", "title": "Pipeline — alertas fallidas activas",
      "description": "Alertas que no pudieron procesarse y aún no fueron resueltas. Indica problemas en el pipeline.",
      "gridPos": { "x": 12, "y": 12, "w": 6, "h": 4 },
      "datasource": { "type": "postgres", "uid": "siem-postgres" },
      "options": { "colorMode": "background", "graphMode": "none", "textMode": "auto" },
      "fieldConfig": { "defaults": {
        "thresholds": { "mode": "absolute", "steps": [
          { "color": "green", "value": null },
          { "color": "red", "value": 1 }
        ]},
        "mappings": []
      }, "overrides": [] },
      "targets": [{ "datasource": { "uid": "siem-postgres" }, "rawSql": "SELECT count(*) AS value FROM failed_alerts WHERE resolved = false", "format": "table", "rawQuery": true, "refId": "A" }]
    },

    {
      "id": 12, "type": "stat", "title": "Postgres — conexiones idle (posibles leaks)",
      "description": "Conexiones en estado idle. Un número alto sostenido puede indicar connection leaks.",
      "gridPos": { "x": 18, "y": 12, "w": 6, "h": 4 },
      "datasource": { "type": "postgres", "uid": "siem-postgres" },
      "options": { "colorMode": "background", "graphMode": "none", "textMode": "auto" },
      "fieldConfig": { "defaults": {
        "thresholds": { "mode": "absolute", "steps": [
          { "color": "green", "value": null },
          { "color": "yellow", "value": 10 },
          { "color": "red", "value": 20 }
        ]},
        "mappings": []
      }, "overrides": [] },
      "targets": [{ "datasource": { "uid": "siem-postgres" }, "rawSql": "SELECT count(*) AS value FROM pg_stat_activity WHERE datname = 'siem' AND state = 'idle'", "format": "table", "rawQuery": true, "refId": "A" }]
    },

    {
      "id": 13, "type": "timeseries", "title": "Actividad del pipeline — alertas y playbooks por hora",
      "description": "Si las líneas divergen (alertas sin playbooks) indica que n8n no está procesando.",
      "gridPos": { "x": 0, "y": 16, "w": 24, "h": 8 },
      "datasource": { "type": "postgres", "uid": "siem-postgres" },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "fieldConfig": { "defaults": {
        "custom": { "lineWidth": 2, "fillOpacity": 10, "drawStyle": "line", "gradientMode": "opacity" },
        "color": { "mode": "palette-classic" },
        "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] },
        "mappings": []
      }, "overrides": [] },
      "targets": [
        { "datasource": { "uid": "siem-postgres" }, "rawSql": "SELECT date_trunc('hour', ts) AS time, count(*) AS \"Alertas recibidas\" FROM alerts WHERE $__timeFilter(ts) GROUP BY 1 ORDER BY 1", "format": "time_series", "rawQuery": true, "refId": "A" },
        { "datasource": { "uid": "siem-postgres" }, "rawSql": "SELECT date_trunc('hour', executed_at) AS time, count(*) AS \"Playbooks ejecutados\" FROM playbook_runs WHERE $__timeFilter(executed_at) GROUP BY 1 ORDER BY 1", "format": "time_series", "rawQuery": true, "refId": "B" }
      ]
    }

  ],
  "time": { "from": "now-24h", "to": "now" },
  "timepicker": {}
}
