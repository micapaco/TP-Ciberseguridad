    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT src_ip, COUNT(*) as count \nFROM alerts \nWHERE src_ip IS NOT NULL \nGROUP BY src_ip \nORDER BY count DESC \nLIMIT 5\n",
