    {
      "parameters": {
        "jsCode": "const metrics = $('Obtener Métricas').first().json;\nconst ips = $('Top IPs').all();\n\n// Formatear Top IPs\nlet ipList = '';\nips.forEach((item, i) => {\n  ipList += `  ${i+1}. ${item.json.src_ip} (${item.json.count} alertas)\\n`;\n});\n\nconst mttr = Math.round(metrics.mttr_seconds || 0);\nconst now = new Date().toISOString().substring(0, 16).replace('T', ' ');\n\nconst report = `📊 REPORTE DIARIO SIEM — ${now}\n━━━━━━━━━━━━━━━━━━\n\n📈 RESUMEN\n  Total alertas: ${metrics.total_alerts}\n  Últimas 24h: ${metrics.alerts_24h}\n  Últimos 7 días: ${metrics.alerts_7d}\n\n⏱️ MÉTRICAS KPI\n  MTTR: ${mttr}s\n  Automatización: ${metrics.auto_rate}%\n\n🔒 INCIDENTES\n  Abiertos: ${metrics.open_incidents}\n  Total: ${metrics.total_incidents}\n  Alertas fallidas: ${metrics.failed_count}\n\n🌐 TOP 5 IPs SOSPECHOSAS\n${ipList || '  Sin datos'}\n━━━━━━━━━━━━━━━━━━\n🤖 Reporte automático del SIEM`;\n\nreturn [{ json: { report } }];\n"
      },
