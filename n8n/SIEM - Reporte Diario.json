    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT \n  (SELECT COUNT(*) FROM alerts) as total_alerts,\n  (SELECT COUNT(*) FROM alerts WHERE ts > NOW() - INTERVAL '24 hours') as alerts_24h,\n  (SELECT COUNT(*) FROM alerts WHERE ts > NOW() - INTERVAL '7 days') as alerts_7d,\n  (SELECT COUNT(*) FROM incidents WHERE status = 'open') as open_incidents,\n  (SELECT COUNT(*) FROM incidents) as total_incidents,\n  (SELECT COALESCE(ROUND(AVG(EXTRACT(EPOCH FROM (p.executed_at - a.ts)))::numeric, 2), 0) FROM alerts a JOIN playbook_runs p ON p.alert_id = a.id) as mttr_seconds,\n  (SELECT COALESCE(ROUND(COUNT(DISTINCT p.alert_id)::numeric / NULLIF((SELECT COUNT(*) FROM alerts), 0) * 100, 2), 0) FROM playbook_runs p) as auto_rate,\n  (SELECT COUNT(*) FROM failed_alerts WHERE resolved = false) as failed_count\n",
        "options": {}
      },
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.6,
      "position": [
        208,
        0
      ],
      "id": "0f64a551-6475-4356-8f92-740db7993fd5",
